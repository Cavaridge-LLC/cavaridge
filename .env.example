# Cavaridge Monorepo — Environment Variables
# Copy to .env and fill in values. NEVER commit .env files.

# Supabase (per-app — each app has its own project)
# Set these in each app's Vercel project env vars for production.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# LLM — OpenRouter (portfolio-wide, single key)
OPENROUTER_API_KEY=

# Supabase MCP (for Claude Code access — your personal access token)
SUPABASE_ACCESS_TOKEN=

# GitHub PAT (for Claude Code MCP — your personal access token)
GITHUB_PERSONAL_ACCESS_TOKEN=
