{
  "name": "@cavaridge/brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs --external:ws --external:pg --external:pg-native",
    "build:client": "vite build",
    "start": "node dist/index.cjs",
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite"
  },
  "dependencies": {
    "express": "^5.1.0",
    "ws": "^8.18.0",
    "pg": "^8.13.0",
    "drizzle-orm": "^0.39.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@cavaridge/spaniel": "workspace:*",
    "@cavaridge/agent-core": "workspace:*",
    "@cavaridge/agents": "workspace:*",
    "@cavaridge/domain-agents": "workspace:*",
    "@cavaridge/connector-core": "workspace:*",
    "@cavaridge/auth": "workspace:*",
    "@cavaridge/ui": "workspace:*",
    "@cavaridge/config": "workspace:*",
    "@cavaridge/ducky-animations": "workspace:*",
    "@cavaridge/security": "workspace:*",
    "@cavaridge/audit": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.0.0",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
