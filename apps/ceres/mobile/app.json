{
  "expo": {
    "name": "Ceres — Medicare Visit Calculator",
    "slug": "ceres",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "ceres",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cavaridge.ceres",
      "infoPlist": {
        "NSCameraUsageDescription": "Ceres uses the camera to scan EMR schedules and extract visit frequency data.",
        "NSPhotoLibraryUsageDescription": "Ceres accesses your photo library to scan EMR schedule images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.cavaridge.ceres",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ceres accesses your photos to scan EMR schedule images.",
          "cameraPermission": "Ceres uses the camera to scan EMR schedules."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": null,
      "eas": {
        "projectId": ""
      }
    },
    "owner": "cavaridge"
  }
}
