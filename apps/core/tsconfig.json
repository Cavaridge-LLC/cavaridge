{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "paths": {
      "@cavaridge/auth": ["../../packages/auth/src"],
      "@cavaridge/auth/*": ["../../packages/auth/src/*"],
      "@cavaridge/audit": ["../../packages/audit/src"],
      "@cavaridge/audit/*": ["../../packages/audit/src/*"]
    }
  },
  "include": ["server/**/*", "client/src/**/*"]
}
