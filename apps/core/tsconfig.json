{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "paths": {
      "@cavaridge/auth": ["../../packages/auth/src"],
      "@cavaridge/auth/*": ["../../packages/auth/src/*"],
      "@cavaridge/audit": ["../../packages/audit/src"],
      "@cavaridge/audit/*": ["../../packages/audit/src/*"]
    }
  },
  "include": ["server/**/*", "client/src/**/*"],
  "exclude": ["server/index 2.ts", "server/db 2.ts", "node_modules", "dist"]
}
