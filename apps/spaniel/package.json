{
  "name": "@cavaridge/spaniel-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.mjs --packages=external",
    "start": "NODE_ENV=production node dist/index.mjs",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@cavaridge/spaniel": "workspace:*",
    "express": "^5.0.1",
    "express-rate-limit": "^8.2.1",
    "drizzle-orm": "^0.39.3",
    "postgres": "^3.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.0"
  }
}
