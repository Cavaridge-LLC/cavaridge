{
  "name": "cavaridge",
  "private": true,
  "version": "1.0.0",
  "description": "Cavaridge application portfolio — monorepo",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
