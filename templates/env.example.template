# Cavaridge Application Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# --- Core ---
APP_CODE=CVG-XXX
APP_ENV=development
# Values: development | staging | production

# --- Database ---
DATABASE_URL=

# --- Auth ---
SESSION_SECRET=
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- AI / LLM ---
OPENROUTER_API_KEY=
# Scoped sub-key for this app only — never the master Cavaridge key
# Model selection is in llm.config.js — do not set model names here

# --- Tenant ---
# Default tenant ID for development seeding only
# Production tenants are created through the application
DEFAULT_TENANT_ID=

# --- Theme ---
THEME_DEFAULT=system
# Values: light | dark | system

# --- LLM Config ---
LLM_CONFIG_PATH=./llm.config.js
