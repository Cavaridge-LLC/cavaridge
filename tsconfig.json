{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@cavaridge/ui": ["./packages/ui/src"],
      "@cavaridge/auth": ["./packages/auth/src"],
      "@cavaridge/db": ["./packages/db/src"],
      "@cavaridge/config": ["./packages/config/src"],
      "@cavaridge/config/*": ["./packages/config/src/*"],
      "@cavaridge/types": ["./packages/types/src"],
      "@cavaridge/spaniel": ["./packages/spaniel/src"],
      "@cavaridge/spaniel/*": ["./packages/spaniel/src/*"],
      "@cavaridge/onboarding": ["./packages/onboarding/src"],
      "@cavaridge/onboarding/*": ["./packages/onboarding/src/*"],
      "@cavaridge/security": ["./packages/security/src"],
      "@cavaridge/security/*": ["./packages/security/src/*"],
      "@cavaridge/audit": ["./packages/audit/src"],
      "@cavaridge/audit/*": ["./packages/audit/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
